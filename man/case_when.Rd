new <- ns_wave1_svy |>
  mutate(
    # make a new variable for young partisans
    age_pid = case_when(
      age < 30 & pid3 == 1 ~ "18-29 Democrats",
      age < 30 & pid3 == 2 ~ "18-29 Republicans",
      age < 30 & pid3 \%in\% c(3:4) ~ "18-29 Independents",
